# ============================================================================
# Copy this file to .env (local) and fill in Supabase project values.
# On Vercel, set the same keys under Project Settings → Environment Variables.
# ============================================================================

# --- Database (Supabase Postgres) -------------------------------------------
# Prisma needs TWO connection strings on Supabase:
#   DATABASE_URL  -> pooled connection (port 6543, pgbouncer) for the app
#   DIRECT_URL    -> direct connection (port 5432) for migrations
# Find both in Supabase: Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres"

# Danh sách mật khẩu đăng nhập (ngăn cách bởi dấu phẩy, không có dấu cách ở giữa)
APP_PASSWORDS="abc,123,hanoi,buncha,pho,banhmy,01072026,01012000,31122099"

# --- Supabase client (Phase 2: auth, storage) -------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
