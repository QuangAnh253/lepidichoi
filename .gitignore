# Xem thêm về cách ignore file tại: https://help.github.com/articles/ignoring-files/

# Dependencies (Thư viện)
/node_modules
/.pnp
.pnp.js

# Testing (Kiểm thử)
/coverage

# Next.js
/.next/
/out/

# Production (Sản phẩm build)
/build

# Biến môi trường (Rất quan trọng, KHÔNG để lộ .env)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc (Hệ điều hành / Debug)
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
